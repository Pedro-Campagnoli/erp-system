# --- App ---
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=http://localhost:5173

# --- Postgres (used by docker-compose) ---
POSTGRES_USER=erp
POSTGRES_PASSWORD=erp
POSTGRES_DB=erp_db
POSTGRES_PORT=5432

# --- Prisma ---
DATABASE_URL="postgresql://erp:erp@localhost:5432/erp_db?schema=public"

# --- Auth (JWT) ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# --- Security ---
BCRYPT_SALT_ROUNDS=10

# Liga as rotas de apoio a testes E2E (src/testing/) e a documentação
# Swagger (/api/docs). NUNCA deixe "true" em produção ou em qualquer
# ambiente acessível pela rede fora de dev/CI local — DELETE /api/testing/...
# é destrutivo e é @Public() (sem autenticação).
ENABLE_TESTING_ROUTES=false
