meta {
  name: Excluir papel
  type: http
  seq: 7
}

delete {
  url: {{baseUrl}}/papeis/{{papelDescartavelId}}
  body: none
  auth: inherit
}

docs {
  Falha com 409 se o papel estiver em uso por algum `UsuarioLoja`. Usa
  `{{papelDescartavelId}}` (não `{{papelId}}`) para não afetar o papel
  reaproveitado em `07-Usuarios/acessos > Conceder acesso a loja`.
}
